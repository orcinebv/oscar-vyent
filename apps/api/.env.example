# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oscar_vyent
DB_USER=postgres
DB_PASS=secret

# ─── Mollie Payment Provider ──────────────────────────────────────────────────
# Prefix determines mode: test_ = test mode, live_ = production
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret used for HMAC-SHA256 webhook signature verification
MOLLIE_WEBHOOK_SECRET=your_webhook_secret_here

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Backend public URL — used for Mollie webhook callback
APP_BASE_URL=http://localhost:3000
# Frontend URL — used for Mollie payment redirect
FRONTEND_URL=http://localhost:4200
# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:4200
