{
  "name": "oscar-vyent",
  "version": "1.0.0",
  "description": "Production-grade Dutch ordering & checkout platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "api": "nx serve api",
    "web": "nx serve web",
    "dev": "nx run-many --target=serve --projects=api,web --parallel",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "test:api": "nx test api",
    "test:web": "nx test web",
    "lint": "nx run-many --target=lint --all",
    "migration:run": "nx run api:migration:run",
    "migration:generate": "nx run api:migration:generate",
    "migration:revert": "nx run api:migration:revert",
    "seed": "nx run api:seed",
    "format": "nx format:write"
  },
  "dependencies": {
    "@angular/animations": "21.2.9",
    "@angular/common": "21.2.9",
    "@angular/compiler": "21.2.9",
    "@angular/core": "21.2.9",
    "@angular/forms": "21.2.9",
    "@angular/platform-browser": "21.2.9",
    "@angular/platform-browser-dynamic": "21.2.9",
    "@angular/router": "21.2.9",
    "@mollie/api-client": "^4.5.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/throttler": "^5.1.0",
    "@nestjs/typeorm": "^10.0.2",
    "@ngrx/signals": "^21.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "nest-winston": "^1.9.4",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.2",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.9",
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "^10.3.0",
    "@nx/angular": "22.6.5",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/jest": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/nest": "22.6.5",
    "@nx/node": "22.6.5",
    "@nx/web": "22.6.5",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@types/compression": "^1.7.5",
    "@types/express": "4.17.25",
    "@types/jest": "30.0.0",
    "@types/node": "~20.12.0",
    "@types/pg": "^8.11.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "jest": "30.0.5",
