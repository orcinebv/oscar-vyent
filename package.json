{
  "name": "oscar-vyent",
  "version": "1.0.0",
  "description": "Production-grade Dutch ordering & checkout platform",
  "private": true,
  "workspaces": ["apps/*", "libs/*"],
  "scripts": {
    "api": "nx serve api",
    "web": "nx serve web",
    "dev": "nx run-many --target=serve --projects=api,web --parallel",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "test:api": "nx test api",
    "test:web": "nx test web",
    "lint": "nx run-many --target=lint --all",
    "migration:run": "nx run api:migration:run",
    "migration:generate": "nx run api:migration:generate",
    "migration:revert": "nx run api:migration:revert",
    "seed": "nx run api:seed",
    "format": "nx format:write"
  },
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "@mollie/api-client": "^4.5.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/throttler": "^5.1.0",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "nest-winston": "^1.9.4",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.2",
    "typeorm": "^0.3.20",
    "winston": "^3.13.0",
    "zone.js": "~0.14.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular/cli": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@nx/angular": "^18.3.0",
    "@nx/eslint": "^18.3.0",
    "@nx/eslint-plugin": "^18.3.0",
    "@nx/jest": "^18.3.0",
    "@nx/js": "^18.3.0",
    "@nx/nest": "^18.3.0",
    "@nx/node": "^18.3.0",
    "@nx/web": "^18.3.0",
    "@swc-node/register": "~1.8.0",
    "@swc/core": "~1.4.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "~20.12.0",
    "@types/pg": "^8.11.5",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "nx": "^18.3.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
