{
  "version": 2,
  "installCommand": "npm ci --legacy-peer-deps",
  "buildCommand": "npx nx run-many --target=build --projects=api,web --parallel=false",
  "outputDirectory": "dist/apps/web",
  "functions": {
    "apps/api/src/serverless.ts": {
      "runtime": "nodejs22.x",
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "apps/api/src/serverless.ts" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
