{
  "version": 2,
  "installCommand": "npm ci --legacy-peer-deps",
  "buildCommand": "./node_modules/.bin/nx run-many --target=build --projects=api,web --parallel=false",
  "outputDirectory": "dist/apps/web",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
